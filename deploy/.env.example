# ---------- Database (external, required) ----------
DATABASE_URL=postgresql://postgres:password@localhost:5432/depvault

# ---------- Auth / JWT ----------
JWT_SECRET=<PLACEHOLDER>
JWT_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=7d

# ---------- Encryption ----------
MASTER_ENCRYPTION_KEY=<PLACEHOLDER>

# ---------- CORS / URLs ----------
CORS_ORIGINS=https://depvault.example.com
FRONTEND_URL=https://depvault.example.com

# ---------- GitHub OAuth ----------
GITHUB_CLIENT_ID=<PLACEHOLDER>
GITHUB_CLIENT_SECRET=<PLACEHOLDER>
GITHUB_CALLBACK_URL=https://api.depvault.example.com/api/auth/github/callback

# ---------- Email (Resend) ----------
RESEND_API_KEY=<PLACEHOLDER>
EMAIL_FROM_NAME=DepVault
EMAIL_FROM_ADDRESS=noreply@depvault.com

# ---------- Stripe Billing ----------
STRIPE_SECRET_KEY=<PLACEHOLDER>
STRIPE_WEBHOOK_SECRET=<PLACEHOLDER>

# ---------- Admin Seed ----------
ADMIN_EMAIL=admin@depvault.com
ADMIN_PASSWORD=<PLACEHOLDER>

# ---------- Logging ----------
LOG_LEVEL=info

# ---------- Uploads ----------
UPLOAD_DIR=./uploads
