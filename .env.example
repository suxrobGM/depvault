# ---------- Database (external, required) ----------
DATABASE_URL=postgresql://user:password@your-db-host:5432/depvault

# ---------- Auth / JWT ----------
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ---------- Server Ports ----------
BACKEND_PORT=4000
FRONTEND_PORT=4001

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:4001

# ---------- Logging ----------
LOG_LEVEL=info
