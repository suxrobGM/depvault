# ---------- Database (external, required) ----------
DATABASE_URL=postgresql://user:password@your-db-host:5432/depvault

# ---------- Auth / JWT ----------
JWT_SECRET=change-me-to-a-secure-random-string-64-chars-minimum
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ---------- Encryption ----------
MASTER_ENCRYPTION_KEY=change-me-exactly-64-hex-chars-for-aes256gcm-encryption-key-here

# ---------- Server Ports ----------
BACKEND_PORT=4000
FRONTEND_PORT=4001

# ---------- CORS / URLs ----------
CORS_ORIGINS=https://depvault.example.com
FRONTEND_URL=https://depvault.example.com
NEXT_PUBLIC_API_URL=https://api.depvault.example.com

# ---------- GitHub OAuth ----------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.depvault.example.com/api/auth/github/callback

# ---------- Email (Resend) ----------
RESEND_API_KEY=
EMAIL_FROM_NAME=DepVault
EMAIL_FROM_ADDRESS=noreply@depvault.dev

# ---------- Logging ----------
LOG_LEVEL=info

# ---------- Uploads ----------
UPLOAD_DIR=./uploads
