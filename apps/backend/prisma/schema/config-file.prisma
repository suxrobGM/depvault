model ConfigFile {
  id               String   @id @default(uuid()) @db.Uuid
  appId            String   @map("app_id") @db.Uuid
  relativePath     String   @map("relative_path")
  format           String
  environmentSlug  String   @map("environment_slug")
  encryptedContent Bytes    @map("encrypted_content")
  iv               String
  authTag          String   @map("auth_tag")
  fileSize         Int      @map("file_size")
  isBinary         Boolean  @default(false) @map("is_binary")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  app      App                 @relation(fields: [appId], references: [id], onDelete: Cascade)
  versions ConfigFileVersion[]

  @@unique([appId, relativePath])
  @@index([appId, environmentSlug])
  @@map("config_files")
}

model ConfigFileVersion {
  id               String   @id @default(uuid()) @db.Uuid
  configFileId     String   @map("config_file_id") @db.Uuid
  encryptedContent Bytes    @map("encrypted_content")
  iv               String
  authTag          String   @map("auth_tag")
  fileSize         Int      @map("file_size")
  isBinary         Boolean  @default(false) @map("is_binary")
  changedBy        String   @map("changed_by") @db.Uuid
  message          String?
  createdAt        DateTime @default(now()) @map("created_at")

  configFile ConfigFile @relation(fields: [configFileId], references: [id], onDelete: Cascade)

  @@index([configFileId])
  @@map("config_file_versions")
}
