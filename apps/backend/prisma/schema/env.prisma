enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PRODUCTION
  GLOBAL
}

model VaultGroup {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  name          String
  description   String?
  directoryPath String?  @map("directory_path")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environments Environment[]
  secretFiles  SecretFile[]

  @@unique([projectId, name])
  @@map("vault_groups")
}

model Environment {
  id           String          @id @default(uuid()) @db.Uuid
  projectId    String          @map("project_id") @db.Uuid
  vaultGroupId String          @map("vault_group_id") @db.Uuid
  type         EnvironmentType @default(DEVELOPMENT)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vaultGroup VaultGroup    @relation(fields: [vaultGroupId], references: [id], onDelete: Cascade)
  variables  EnvVariable[]
  ciTokens   CiToken[]

  @@unique([vaultGroupId, type])
  @@map("environments")
}

model EnvVariable {
  id               String   @id @default(uuid()) @db.Uuid
  environmentId    String   @map("environment_id") @db.Uuid
  key              String
  encryptedValue   String   @map("encrypted_value")
  iv               String
  authTag          String   @map("auth_tag")
  sortOrder        Int?     @map("sort_order")
  encryptedComment String?  @map("encrypted_comment")
  commentIv        String?  @map("comment_iv")
  commentAuthTag   String?  @map("comment_auth_tag")
  description      String?
  isRequired       Boolean  @default(false) @map("is_required")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  environment Environment          @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  versions    EnvVariableVersion[]

  @@unique([environmentId, key])
  @@map("env_variables")
}

model EnvVariableVersion {
  id             String   @id @default(uuid()) @db.Uuid
  variableId     String   @map("variable_id") @db.Uuid
  encryptedValue String   @map("encrypted_value")
  iv             String
  authTag        String   @map("auth_tag")
  changedBy      String   @map("changed_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  variable EnvVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)

  @@map("env_variable_versions")
}

model EnvTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String
  description String?
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator   User                  @relation("envTemplateCreator", fields: [createdBy], references: [id])
  variables EnvTemplateVariable[]

  @@unique([projectId, name])
  @@map("env_templates")
}

model EnvTemplateVariable {
  id          String  @id @default(uuid()) @db.Uuid
  templateId  String  @map("template_id") @db.Uuid
  key         String
  description String?
  isRequired  Boolean @default(false) @map("is_required")
  sortOrder   Int     @default(0) @map("sort_order")

  template EnvTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@map("env_template_variables")
}
