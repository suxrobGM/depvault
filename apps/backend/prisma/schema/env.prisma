enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PRODUCTION
  CUSTOM
}

model Environment {
  id        String          @id @default(uuid()) @db.Uuid
  projectId String          @map("project_id") @db.Uuid
  name      String
  type      EnvironmentType @default(DEVELOPMENT)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  variables   EnvVariable[]
  secretFiles SecretFile[]

  @@unique([projectId, name])
  @@map("environments")
}

model EnvVariable {
  id             String    @id @default(uuid()) @db.Uuid
  environmentId  String    @map("environment_id") @db.Uuid
  key            String
  encryptedValue String    @map("encrypted_value")
  iv             String
  authTag        String    @map("auth_tag")
  description    String?
  isRequired     Boolean   @default(false) @map("is_required")
  validationRule String?   @map("validation_rule")
  rotationDays   Int?      @map("rotation_days")
  lastRotatedAt  DateTime? @map("last_rotated_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  environment Environment          @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  versions    EnvVariableVersion[]

  @@unique([environmentId, key])
  @@map("env_variables")
}

model EnvVariableVersion {
  id             String   @id @default(uuid()) @db.Uuid
  variableId     String   @map("variable_id") @db.Uuid
  encryptedValue String   @map("encrypted_value")
  iv             String
  authTag        String   @map("auth_tag")
  changedBy      String   @map("changed_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  variable EnvVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)

  @@map("env_variable_versions")
}

model EnvTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String
  description String?
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator   User                  @relation("envTemplateCreator", fields: [createdBy], references: [id])
  variables EnvTemplateVariable[]

  @@unique([projectId, name])
  @@map("env_templates")
}

model EnvTemplateVariable {
  id             String  @id @default(uuid()) @db.Uuid
  templateId     String  @map("template_id") @db.Uuid
  key            String
  description    String?
  isRequired     Boolean @default(false) @map("is_required")
  validationRule String? @map("validation_rule")
  sortOrder      Int     @default(0) @map("sort_order")

  template EnvTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@map("env_template_variables")
}

enum SecretFileAuditAction {
  UPLOADED
  DOWNLOADED
  DELETED
}

model SecretFile {
  id               String   @id @default(uuid()) @db.Uuid
  environmentId    String   @map("environment_id") @db.Uuid
  name             String
  description      String?
  encryptedContent Bytes    @map("encrypted_content")
  iv               String
  authTag          String   @map("auth_tag")
  mimeType         String   @map("mime_type")
  fileSize         Int      @map("file_size")
  uploadedBy       String   @map("uploaded_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  environment Environment          @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  uploader    User                 @relation(fields: [uploadedBy], references: [id])
  versions    SecretFileVersion[]
  auditLogs   SecretFileAuditLog[]

  @@unique([environmentId, name])
  @@map("secret_files")
}

model SecretFileVersion {
  id               String   @id @default(uuid()) @db.Uuid
  secretFileId     String   @map("secret_file_id") @db.Uuid
  encryptedContent Bytes    @map("encrypted_content")
  iv               String
  authTag          String   @map("auth_tag")
  fileSize         Int      @map("file_size")
  changedBy        String   @map("changed_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  secretFile SecretFile @relation(fields: [secretFileId], references: [id], onDelete: Cascade)

  @@map("secret_file_versions")
}

model SecretFileAuditLog {
  id           String                @id @default(uuid()) @db.Uuid
  secretFileId String                @map("secret_file_id") @db.Uuid
  userId       String                @map("user_id") @db.Uuid
  action       SecretFileAuditAction
  createdAt    DateTime              @default(now()) @map("created_at")

  secretFile SecretFile @relation(fields: [secretFileId], references: [id], onDelete: Cascade)

  @@map("secret_file_audit_logs")
}
