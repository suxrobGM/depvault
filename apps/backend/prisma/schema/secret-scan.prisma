enum DetectionSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DetectionStatus {
  OPEN
  RESOLVED
  FALSE_POSITIVE
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ScanPattern {
  id        String            @id @default(uuid()) @db.Uuid
  projectId String?           @map("project_id") @db.Uuid
  name      String
  regex     String
  severity  DetectionSeverity
  isBuiltIn Boolean           @default(false) @map("is_built_in")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  project    Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  detections SecretDetection[]

  @@map("scan_patterns")
}

model SecretScan {
  id              String     @id @default(uuid()) @db.Uuid
  projectId       String     @map("project_id") @db.Uuid
  triggeredById   String     @map("triggered_by_id") @db.Uuid
  status          ScanStatus @default(PENDING)
  commitsScanned  Int        @default(0) @map("commits_scanned")
  detectionsFound Int        @default(0) @map("detections_found")
  startedAt       DateTime?  @map("started_at")
  completedAt     DateTime?  @map("completed_at")
  errorMessage    String?    @map("error_message")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy User              @relation("scanTriggeredBy", fields: [triggeredById], references: [id])
  detections  SecretDetection[]

  @@map("secret_scans")
}

model SecretDetection {
  id               String          @id @default(uuid()) @db.Uuid
  projectId        String          @map("project_id") @db.Uuid
  scanId           String          @map("scan_id") @db.Uuid
  scanPatternId    String          @map("scan_pattern_id") @db.Uuid
  commitHash       String          @map("commit_hash")
  filePath         String          @map("file_path")
  lineNumber       Int?            @map("line_number")
  matchSnippet     String          @map("match_snippet")
  status           DetectionStatus @default(OPEN)
  resolvedById     String?         @map("resolved_by_id") @db.Uuid
  resolvedAt       DateTime?       @map("resolved_at")
  remediationSteps String?         @map("remediation_steps")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scan        SecretScan  @relation(fields: [scanId], references: [id], onDelete: Cascade)
  scanPattern ScanPattern @relation(fields: [scanPatternId], references: [id])
  resolvedBy  User?       @relation("detectionResolvedBy", fields: [resolvedById], references: [id])

  @@index([projectId, status])
  @@map("secret_detections")
}
