/// Repo-native vault model: Project -> App -> ConfigFile / SecretFile.
/// A config/secret file is stored as one encrypted blob (the source of truth for pull);
/// the web parses it client-side. Environment is a column (open-set slug), not a table.

model App {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  name      String
  appPath   String   @map("app_path")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  configFiles ConfigFile[]
  secretFiles SecretFile[]
  ciTokens    CiToken[]

  @@unique([projectId, appPath])
  @@map("apps")
}
