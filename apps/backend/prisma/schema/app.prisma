/**
 * Repo-native model: Project -> App -> ConfigFile / SecretFile.
 * An App is one application/service root folder in the repo, identified by its
 * repo-relative `appPath`. Config files live in config-file.prisma; secret files in
 * secret.prisma. Environment is an open-set slug column on each file, not a table.
 */

model App {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  name      String
  appPath   String   @map("app_path")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  configFiles ConfigFile[]
  secretFiles SecretFile[]
  ciTokens    CiToken[]

  @@unique([projectId, appPath])
  @@map("apps")
}
