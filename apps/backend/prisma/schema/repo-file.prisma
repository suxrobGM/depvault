/**
 * Unified repo file model: one client-encrypted blob per file in a repo, replacing the
 * former ConfigFile/SecretFile split. `kind` distinguishes an editable config (key/value
 * Form view) from a secret artifact (raw/download-only). Identity is the repo-root-relative
 * `relativePath` within a project; `appId` is a mutable grouping pointer (re-grouping a file
 * when project markers change updates the same row and keeps its history).
 */

enum RepoFileKind {
  CONFIG
  SECRET
}

model RepoFile {
  id               String       @id @default(uuid()) @db.Uuid
  projectId        String       @map("project_id") @db.Uuid
  appId            String       @map("app_id") @db.Uuid
  kind             RepoFileKind
  relativePath     String       @map("relative_path")
  environmentSlug  String?      @map("environment_slug")
  format           String?
  mimeType         String?      @map("mime_type")
  description      String?
  encryptedContent Bytes        @map("encrypted_content")
  iv               String
  authTag          String       @map("auth_tag")
  fileSize         Int          @map("file_size")
  isBinary         Boolean      @default(false) @map("is_binary")
  // Keyed HMAC of the plaintext (key derived from the project DEK) used to detect a no-op push
  // and skip snapshotting a redundant version. Opaque to the server; null = unknown (never skip).
  contentHash      String?      @map("content_hash")
  createdBy        String       @map("created_by") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  app      App               @relation(fields: [appId], references: [id], onDelete: Cascade)
  creator  User              @relation(fields: [createdBy], references: [id])
  versions RepoFileVersion[]

  @@unique([projectId, relativePath])
  @@index([appId])
  @@index([appId, kind])
  @@index([projectId, environmentSlug])
  @@map("repo_files")
}

model RepoFileVersion {
  id               String   @id @default(uuid()) @db.Uuid
  repoFileId       String   @map("repo_file_id") @db.Uuid
  encryptedContent Bytes    @map("encrypted_content")
  iv               String
  authTag          String   @map("auth_tag")
  fileSize         Int      @map("file_size")
  isBinary         Boolean  @default(false) @map("is_binary")
  changedBy        String   @map("changed_by") @db.Uuid
  message          String?
  createdAt        DateTime @default(now()) @map("created_at")

  repoFile RepoFile @relation(fields: [repoFileId], references: [id], onDelete: Cascade)

  @@index([repoFileId])
  @@map("repo_file_versions")
}
