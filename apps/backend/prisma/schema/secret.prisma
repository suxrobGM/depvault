enum SharedSecretStatus {
  PENDING
  VIEWED
  EXPIRED
}

enum SharedSecretType {
  CONFIG_FILE
  SECRET_FILE
}

model SharedSecret {
  id               String             @id @default(uuid()) @db.Uuid
  creatorId        String             @map("creator_id") @db.Uuid
  projectId        String             @map("project_id") @db.Uuid
  token            String             @unique
  encryptedPayload String             @map("encrypted_payload")
  iv               String
  authTag          String             @map("auth_tag")
  passwordHash     String?            @map("password_hash")
  payloadType      SharedSecretType   @default(CONFIG_FILE) @map("payload_type")
  fileName         String?            @map("file_name")
  mimeType         String?            @map("mime_type")
  status           SharedSecretStatus @default(PENDING)
  expiresAt        DateTime           @map("expires_at")
  viewedAt         DateTime?          @map("viewed_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  creator User    @relation(fields: [creatorId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("shared_secrets")
}

model SecretFile {
  id               String   @id @default(uuid()) @db.Uuid
  appId            String   @map("app_id") @db.Uuid
  relativePath     String   @map("relative_path")
  environmentSlug  String?  @map("environment_slug")
  description      String?
  encryptedContent Bytes    @map("encrypted_content")
  iv               String
  authTag          String   @map("auth_tag")
  mimeType         String   @map("mime_type")
  fileSize         Int      @map("file_size")
  isBinary         Boolean  @default(true) @map("is_binary")
  uploadedBy       String   @map("uploaded_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  app      App                 @relation(fields: [appId], references: [id], onDelete: Cascade)
  uploader User                @relation(fields: [uploadedBy], references: [id])
  versions SecretFileVersion[]

  @@unique([appId, relativePath])
  @@index([appId, environmentSlug])
  @@map("secret_files")
}

model SecretFileVersion {
  id               String   @id @default(uuid()) @db.Uuid
  secretFileId     String   @map("secret_file_id") @db.Uuid
  encryptedContent Bytes    @map("encrypted_content")
  iv               String
  authTag          String   @map("auth_tag")
  fileSize         Int      @map("file_size")
  isBinary         Boolean  @default(true) @map("is_binary")
  changedBy        String   @map("changed_by") @db.Uuid
  message          String?
  createdAt        DateTime @default(now()) @map("created_at")

  secretFile SecretFile @relation(fields: [secretFileId], references: [id], onDelete: Cascade)

  @@index([secretFileId])
  @@map("secret_file_versions")
}
