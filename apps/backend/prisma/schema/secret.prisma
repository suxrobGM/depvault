enum SharedSecretStatus {
  PENDING
  VIEWED
  EXPIRED
}

enum SecretAuditAction {
  CREATED
  VIEWED
  EXPIRED
  UPLOADED
  DOWNLOADED
  DELETED
}

model SharedSecret {
  id               String             @id @default(uuid()) @db.Uuid
  creatorId        String             @map("creator_id") @db.Uuid
  token            String             @unique
  encryptedPayload String             @map("encrypted_payload")
  iv               String
  authTag          String             @map("auth_tag")
  passwordHash     String?            @map("password_hash")
  status           SharedSecretStatus @default(PENDING)
  expiresAt        DateTime           @map("expires_at")
  viewedAt         DateTime?          @map("viewed_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  creator   User             @relation(fields: [creatorId], references: [id])
  auditLogs SecretAuditLog[]

  @@map("shared_secrets")
}

model SecretAuditLog {
  id        String            @id @default(uuid()) @db.Uuid
  secretId  String            @map("secret_id") @db.Uuid
  userId    String?           @map("user_id") @db.Uuid
  action    SecretAuditAction
  ip        String?
  createdAt DateTime          @default(now()) @map("created_at")

  secret SharedSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)

  @@map("secret_audit_logs")
}
