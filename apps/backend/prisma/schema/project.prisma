enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

model Project {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  repositoryUrl String?  @map("repository_url")
  ownerId       String   @map("owner_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner            User                @relation(fields: [ownerId], references: [id])
  members          ProjectMember[]
  invitations      ProjectInvitation[]
  analyses         Analysis[]
  vaults           Vault[]
  auditLogs        AuditLog[]
  sharedSecrets    SharedSecret[]
  scanPatterns     ScanPattern[]
  secretScans      SecretScan[]
  secretDetections SecretDetection[]
  ciTokens         CiToken[]
  licenseRules     LicenseRule[]
  keyGrants        ProjectKeyGrant[]

  @@map("projects")
}

model LicenseRule {
  id        String        @id @default(uuid()) @db.Uuid
  projectId String        @map("project_id") @db.Uuid
  licenseId String        @map("license_id")
  policy    LicensePolicy @default(WARN)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, licenseId])
  @@map("license_rules")
}

model ProjectMember {
  id        String      @id @default(uuid()) @db.Uuid
  projectId String      @map("project_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  role      ProjectRole @default(VIEWER)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model ProjectInvitation {
  id          String           @id @default(uuid()) @db.Uuid
  projectId   String           @map("project_id") @db.Uuid
  email       String
  role        ProjectRole      @default(VIEWER)
  status      InvitationStatus @default(PENDING)
  token       String           @unique @default(uuid())
  invitedById String           @map("invited_by_id") @db.Uuid
  userId      String?          @map("user_id") @db.Uuid
  expiresAt   DateTime         @map("expires_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("invitationsSent", fields: [invitedById], references: [id])
  user      User?   @relation("invitationsReceived", fields: [userId], references: [id])

  @@unique([projectId, email, status])
  @@map("project_invitations")
}
