model CiToken {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @map("project_id") @db.Uuid
  vaultId       String    @map("vault_id") @db.Uuid
  createdBy     String    @map("created_by") @db.Uuid
  name          String
  tokenHash     String    @unique @map("token_hash")
  tokenPrefix   String    @map("token_prefix")
  ipAllowlist   String[]  @default([]) @map("ip_allowlist")
  wrappedDek    String?   @map("wrapped_dek")
  wrappedDekIv  String?   @map("wrapped_dek_iv")
  wrappedDekTag String?   @map("wrapped_dek_tag")
  revokedAt     DateTime? @map("revoked_at")
  lastUsedAt    DateTime? @map("last_used_at")
  expiresAt     DateTime  @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vault   Vault   @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([projectId])
  @@map("ci_tokens")
}
