{
  "name": "@depvault/cli-ts",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "depvault": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --outfile dist/depvault src/index.ts",
    "build:linux": "bun build --compile --target bun-linux-x64 --outfile dist/depvault-linux src/index.ts",
    "build:macos": "bun build --compile --target bun-darwin-arm64 --outfile dist/depvault-macos src/index.ts",
    "build:windows": "bun build --compile --target bun-windows-x64 --outfile dist/depvault.exe src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@depvault/crypto": "workspace:*",
    "@depvault/shared": "workspace:*",
    "@elysiajs/eden": "^1.4.8",
    "@inkjs/ui": "^2.0.0",
    "clipanion": "^4.0.0-rc.4",
    "elysia": "^1.4.25",
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  }
}
